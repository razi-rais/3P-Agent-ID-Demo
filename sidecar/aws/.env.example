# AWS Bedrock Edition — Environment Variables
# Copy to .env and fill in your values.
#
# =============================================================================
# ⚠️  .env IS FOR LOCAL DEVELOPMENT ONLY — NEVER DEPLOY IT TO PRODUCTION  ⚠️
# =============================================================================
# This file pattern stores secrets in plaintext. It is gitignored. .env must
# never be committed, shared, or copied to shared/remote environments.
#
# PRODUCTION on Azure App Service should use (zero stored secrets):
#   • Entra: BLUEPRINT_CLIENT_SECRET → SourceType=SignedAssertionFromManagedIdentity
#   • AWS:   STS creds/API keys → OIDC federation
#            (Managed Identity → AssumeRoleWithWebIdentity, rotated auto)
#            Set AWS_ROLE_ARN + AWS_WEB_IDENTITY_TOKEN_FILE in App Settings,
#            delete AWS_ACCESS_KEY_ID / SECRET / SESSION_TOKEN entirely.
# See: https://github.com/AzureAD/microsoft-identity-web/wiki/Client-Credentials
# =============================================================================

# Microsoft Entra Agent ID
TENANT_ID=
BLUEPRINT_APP_ID=
AGENT_CLIENT_ID=
CLIENT_SPA_APP_ID=

# Blueprint Client Credential (used by the auth sidecar)
# ⚠️ Dev-only. In prod, remove this and set SourceType=SignedAssertionFromManagedIdentity.
BLUEPRINT_CLIENT_SECRET=

# AWS Bedrock
# Pick ONE of the three auth methods below. Dev/demo = A or B; prod = C.
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# ─── (A) Temporary STS credentials — local dev via SSO ───────────────────────
# Easiest if your org uses AWS IAM Identity Center (aws sso login).
# ⚠️ Expires (~1h); re-export from the SSO portal when it does.
# ⚠️ NEVER use in production.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ─── (B) Bedrock API key — simplest for public demo / hands-on workshops ─────
# Create in Bedrock console → API keys → Create key (long- or short-term).
# Single env var, scoped to Bedrock only. Safer than full IAM keys.
# Comment out (A) above if using this.
# AWS_BEARER_TOKEN_BEDROCK=ABSK...

# ─── (C) OIDC federation — PRODUCTION on Azure App Service ───────────────────
# NO SECRETS in .env. Configure at the platform level instead:
#   App Service → Identity → System-assigned = On
#   App Settings: AWS_ROLE_ARN=arn:aws:iam::<acct>:role/BedrockInvokerFromAzure
#                 AWS_WEB_IDENTITY_TOKEN_FILE=/tmp/azure-token
#   AWS IAM role trust policy: trusts Entra OIDC provider, audience
#                              api://AzureADTokenExchange, sub = MI object ID.
# boto3 auto-refreshes creds via AssumeRoleWithWebIdentity (~1h rotation).
