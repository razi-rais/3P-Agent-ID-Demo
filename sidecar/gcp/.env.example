# Google Vertex AI Edition — Environment Variables
# Copy to .env and fill in your values

# Microsoft Entra Agent ID
TENANT_ID=
BLUEPRINT_APP_ID=
AGENT_CLIENT_ID=

# Blueprint Client Credential (used by the auth sidecar)
# For local dev: SourceType=ClientSecret (set in docker-compose.yml)
# For production on Azure: use SignedAssertionFromManagedIdentity (zero secrets)
# See: https://github.com/AzureAD/microsoft-identity-web/wiki/Client-Credentials
BLUEPRINT_CLIENT_SECRET=

# Google Cloud
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
VERTEXAI_MODEL_ID=gemini-1.0-pro-002
# Place your GCP service account key as vertex-ai-key.json in this folder
